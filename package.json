{
  "name": "brightweb-platform",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "check:base-contract": "node ./scripts/validate-base-contract.mjs",
    "changeset": "changeset",
    "create:client": "node ./scripts/create-brightweb-client.mjs",
    "db:materialize": "node ./scripts/materialize-client-migrations.mjs",
    "db:new": "node ./scripts/new-migration.mjs",
    "db:plan": "node ./scripts/plan-client-migrations.mjs",
    "dev": "pnpm --filter platform-preview dev",
    "dev:docs": "pnpm --filter dev-docs dev",
    "build": "pnpm --filter platform-preview build",
    "build:docs": "pnpm --filter dev-docs build",
    "release:check": "changeset status --verbose",
    "release:version": "changeset version && pnpm install --lockfile-only",
    "release:publish": "changeset publish",
    "start": "pnpm --filter platform-preview start",
    "start:docs": "pnpm --filter dev-docs start",
    "test": "node --experimental-strip-types --test ./tests/base-contract-contracts.test.ts",
    "lint": "pnpm --filter platform-preview lint",
    "lint:docs": "pnpm --filter dev-docs lint"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/react": "^19",
    "@types/react-dom": "^19"
  }
}
