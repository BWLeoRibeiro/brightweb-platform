{
  "name": "brightweb-platform",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "check:base-contract": "node ./scripts/validate-base-contract.mjs",
    "check:compatibility-set": "node ./scripts/validate-compatibility-set.mjs",
    "check:create-bw-app-templates": "node ./scripts/check-create-bw-app-templates.mjs",
    "check:module-manifest": "node ./scripts/validate-module-manifest.mjs",
    "changeset": "changeset",
    "create:client": "node ./scripts/create-brightweb-client.mjs",
    "db:materialize": "node ./scripts/materialize-client-migrations.mjs",
    "db:new": "node ./scripts/new-migration.mjs",
    "db:plan": "node ./scripts/plan-client-migrations.mjs",
    "dev": "pnpm --filter platform-preview dev",
    "dev:docs": "pnpm --filter dev-docs dev",
    "build": "pnpm --filter platform-preview build",
    "build:docs": "pnpm --filter dev-docs build",
    "release:check": "changeset status --verbose",
    "release:version": "changeset version && node ./scripts/sync-compatibility-set.mjs",
    "release:publish": "changeset publish",
    "start": "pnpm --filter platform-preview start",
    "start:docs": "pnpm --filter dev-docs start",
    "test": "node --experimental-strip-types --loader ./tests/support/ts-extension-loader.mjs --test ./tests/app-shell-config.test.ts ./tests/app-shell-theme.test.ts ./tests/base-contract-contracts.test.ts ./tests/compatibility-set-sync.test.ts ./tests/core-auth-ui.test.ts ./tests/create-bw-app-update.test.ts ./tests/create-bw-app-cli.test.ts ./tests/module-crm-ui.test.ts ./tests/module-crm-writes.test.ts ./tests/module-projects-ui.test.ts ./tests/module-manifest-validator.test.ts ./tests/template-thinness.test.ts ./tests/theme-contract.test.ts ./tests/ui-hygiene.test.ts ./tests/ui-patterns.test.ts",
    "lint": "pnpm --filter platform-preview lint",
    "lint:docs": "pnpm --filter dev-docs lint"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/react": "^19",
    "@types/react-dom": "^19"
  }
}
