{
  "contractVersion": 1,
  "key": "projects",
  "title": "Projects",
  "description": "Projects, tasks, milestones, members, links, and project activity policies.",
  "requires": {
    "core": ">=0.4",
    "admin": ">=0.3",
    "orgs": ">=0.1"
  },
  "capabilities": {
